Basemat:
  Pipelines:
    - RenderPass: DefaultReflection
      DepthTest: false
      DepthWrite: false
      CullMode: None
      PolygonMode: Fill
      TopologyMode: TriangleList
      Vertex: Shaders/DefaultReflection.vert
      Fragment: Shaders/DefaultReflection.frag
      DescriptorSets:
        - Type: Renderer
          RenderPass: DefaultReflection
          Set: 0
        - Type: Bindless
          RenderPass: DefaultReflection
          Set: 1
        - Type: Scene
          RenderPass: DefaultReflection
          Set: 2
      VertexInputBindingDescriptions:
        - Binding: 0
          InputRate: Vertex
          Tag: Position
          Names:
            - positionA
      ColorBlendStates:
        - BlendEnabled: false

Basemat:
  Pipelines:
    - RenderPass: SSS
      Type: Compute
      Compute: Shaders/SSS.comp
      UniformWriters:
        - Type: Renderer
          Name: SSS
          Set: 0
        - Type: Renderer
          Name: Camera
          Set: 1
        - Type: Renderer
          Name: Lights
          Set: 2
      Uniforms:
        - Name: depthTexture
          TextureAttachment: "GBuffer[4]"

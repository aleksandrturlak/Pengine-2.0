Basemat:
  Pipelines:
    - RenderPass: SSAO
      Type: Compute
      Compute: Shaders/SSAO.comp
      UniformWriters:
        - Type: Renderer
          Name: SSAO
          Set: 0
        - Type: Renderer
          Name: Camera
          Set: 1
      Uniforms:
        - Name: normalTexture
          TextureAttachment: "GBuffer[1]"
        - Name: depthTexture
          TextureAttachment: "GBuffer[4]"
